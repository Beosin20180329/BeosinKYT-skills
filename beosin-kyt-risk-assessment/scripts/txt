#!/usr/bin/env python3
"""
Token Address Lookup Tool
For looking up token contract addresses from currency_basket_output.json
"""

import json
import sys
import os
import argparse

SCRIPT_DIR = os.path.dirname(os.path.abspath(__file__))
CURRENCY_BASKET_PATH = os.path.join(SCRIPT_DIR, "currency_basket_output.json")

CHAIN_ID_MAP = {
    "btc": "0",
    "eth": "1",
    "bsc": "56",
    "tron": "79",
    "polygon": "137",
    "avalanche": "43114",
    "arbitrum": "42161",
    "optimism": "10",
    "ltc": "227",
    "aptos": "aptos",
    "kaia": "8217",
    "solana": "solana",
    "ton": "ton",
    "xrp": "xrp",
    "zksync": "324",
    "iotex": "4689",
    "hsk": "177",
    "klaytn": "8217",
}

def load_currency_basket():
    """Load token mapping file"""
    if not os.path.exists(CURRENCY_BASKET_PATH):
        return None
    with open(CURRENCY_BASKET_PATH, 'r', encoding='utf-8') as f:
        return json.load(f)

def get_address(chain: str, symbol: str) -> str:
    """
    Look up token address

    Args:
        chain: Chain name (e.g., ETH, BSC, SOLANA)
        symbol: Token symbol (e.g., USDT, SHIB)

    Returns:
        Token address, or None if not found
    """
    data = load_currency_basket()
    if not data:
        return None

    chain = chain.upper()
    symbol = symbol.upper()

    if chain in data:
        tokens = data[chain].get("tokens", {})
        if symbol in tokens:
            return tokens[symbol]

    return None

def list_tokens(chain: str) -> list:
    """
    List all tokens on the specified chain

    Args:
        chain: Chain name

    Returns:
        List of tokens
    """
    data = load_currency_basket()
    if not data:
        return []

    chain = chain.upper()

    if chain in data:
        tokens = data[chain].get("tokens", {})
        return [(symbol, address) for symbol, address in tokens.items()]

    return []

def list_chains() -> list:
    """List all supported chains"""
    data = load_currency_basket()
    if not data:
        return []

    return list(data.keys())

def format_address(chain: str, symbol: str, address: str) -> str:
    """Format output"""
    chain_id = CHAIN_ID_MAP.get(chain.lower(), "unknown")
    return f"{chain}/{symbol}: {address} (chainId: {chain_id})"

if __name__ == "__main__":
    parser = argparse.ArgumentParser(description="Token Address Lookup Tool")
    parser.add_argument("command", nargs="?", help="Command: get_address, list_tokens, list_chains")
    parser.add_argument("param1", nargs="?", help="Chain name or token symbol")
    parser.add_argument("param2", nargs="?", help="Token symbol")

    args = parser.parse_args()

    if not args.command:
        print("Usage:")
        print("  python txt get_address <chain> <symbol>")
        print("  python txt list_tokens <chain>")
        print("  python txt list_chains")
        print("\nExamples:")
        print("  python txt get_address ETH SHIB")
        print("  python txt get_address BSC USDT")
        print("  python txt get_address SOLANA BONK")
        print("  python txt list_tokens ETH")
        print("  python txt list_chains")
        sys.exit(1)

    command = args.command

    if command == "get_address":
        if not args.param1 or not args.param2:
            print("Error: Please provide chain name and token symbol")
            print("Example: python txt get_address ETH SHIB")
            sys.exit(1)

        address = get_address(args.param1, args.param2)
        if address:
            print(format_address(args.param1, args.param2, address))
        else:
            print(f"Token not found: {args.param2} @ {args.param1}")

    elif command == "list_tokens":
        if not args.param1:
            print("Error: Please provide chain name")
            print("Example: python txt list_tokens ETH")
            sys.exit(1)

        tokens = list_tokens(args.param1)
        if tokens:
            print(f"Tokens on {args.param1} ({len(tokens)} total):")
            for symbol, address in sorted(tokens):
                print(f"  {symbol}: {address}")
        else:
            print(f"Chain not found: {args.param1} or no tokens on this chain")

    elif command == "list_chains":
        chains = list_chains()
        print(f"Supported chains ({len(chains)} total):")
        for chain in chains:
            print(f"  {chain}")

    else:
        print(f"Unknown command: {command}")
        sys.exit(1)